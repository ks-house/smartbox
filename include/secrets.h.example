#ifndef SECRETS_H
#define SECRETS_H

// ==========================================
// SmartBox Secrets Template
// Rename this file to 'secrets.h' and fill
// in your real values. 'secrets.h' is gitignored.
// ==========================================

// WiFi Configurations
#define SECRET_WIFI_SSID "YOUR_WIFI_SSID"
#define SECRET_WIFI_PASS "YOUR_WIFI_PASSWORD"

// SoftAP Password (MUST be 8+ characters to prevent open AP)
#define SECRET_AP_PASS "YOUR_AP_PASSWORD_8CHARS_MIN"

// Synology NAS HTTPS OTA URLs
#define SECRET_VERSION_URL "https://your-nas-domain:4443/version.json"
#define SECRET_FIRMWARE_URL "https://your-nas-domain:4443/firmware.bin"

// MQTT Broker Configurations (Synology NAS / Home Assistant)
#define SECRET_MQTT_HOST "your-mqtt-broker-domain"
#define SECRET_MQTT_PORT 4883
#define SECRET_MQTT_USER "your_mqtt_user"
#define SECRET_MQTT_PASS "your_mqtt_password"

// TLS Root CA Certificate for HTTPS & MQTTS verification
#define SECRET_ROOT_CA_CERT R"(
-----BEGIN CERTIFICATE-----
YOUR_ROOT_CA_CERTIFICATE_PEM_CONTENT_HERE
-----END CERTIFICATE-----
)"

#endif // SECRETS_H
