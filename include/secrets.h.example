#ifndef SECRETS_H
#define SECRETS_H

// ==========================================
// SmartBox Secrets Template
// Rename this file to 'secrets.h' and fill
// in your real values. 'secrets.h' is gitignored.
// ==========================================

// WiFi Configurations
#define SECRET_WIFI_SSID "YOUR_WIFI_SSID"
#define SECRET_WIFI_PASS "YOUR_WIFI_PASSWORD"

// InfluxDB Configurations
#define SECRET_INFLUXDB_URL "https://your-influxdb-instance:4085"
#define SECRET_INFLUXDB_TOKEN "YOUR_INFLUXDB_TOKEN"
#define SECRET_INFLUXDB_ORG "smartbox_org"
#define SECRET_INFLUXDB_BUCKET "telemetry"

// Synology NAS HTTPS OTA URLs
#define SECRET_VERSION_URL "https://your-nas-domain:4443/version.json"
#define SECRET_FIRMWARE_URL "https://your-nas-domain:4443/firmware.bin"

// Dashboard HTTP Basic Auth Credentials
#define SECRET_DASHBOARD_USER "admin"
#define SECRET_DASHBOARD_PASS "YOUR_DASHBOARD_PASSWORD"

// SoftAP Password (MUST be 8+ characters to prevent open AP)
// This password is required to connect to SmartBox-WiFi local AP
#define SECRET_AP_PASS "YOUR_AP_PASSWORD_8CHARS_MIN"

// TLS Root CA Certificate for HTTPS verification
// Used by AutoOtaManager (NAS OTA) and TelemetryManager (InfluxDB)
// Instructions:
//   1. Run: openssl s_client -connect your-nas-domain:4443 -showcerts </dev/null 2>/dev/null
//   2. Copy the LAST certificate block (Root CA, not leaf/intermediate)
//   3. Or download ISRG Root X1 from: https://letsencrypt.org/certs/isrgrootx1.pem
//   4. Paste the PEM content below between the R"(...)" delimiters
#define SECRET_ROOT_CA_CERT R"(
-----BEGIN CERTIFICATE-----
YOUR_ROOT_CA_CERTIFICATE_PEM_CONTENT_HERE
-----END CERTIFICATE-----
)"

// MQTT Broker Configurations
#define SECRET_MQTT_HOST "your-mqtt-broker-domain"
#define SECRET_MQTT_PORT 4883
#define SECRET_MQTT_USER "your_mqtt_user"
#define SECRET_MQTT_PASS "your_mqtt_password"

#endif // SECRETS_H
